{
    "security": {
        "encryption": {
            "enabled": true,
            "algorithm": "AES-256-GCM",
            "key_derivation": "PBKDF2",
            "iterations": 100000
        },
        "key_management": {
            "rotation_interval": 86400,
            "key_length": 32,
            "backup_count": 3,
            "storage": {
                "type": "file",
                "path": ".config/credentials/keys",
                "permissions": "0600"
            }
        },
        "access_control": {
            "enabled": true,
            "default_policy": "deny",
            "roles": [
                {
                    "name": "admin",
                    "permissions": ["read", "write", "delete", "rotate"]
                },
                {
                    "name": "service",
                    "permissions": ["read"]
                }
            ]
        }
    },
    "providers": {
        "ollama": {
            "type": "api_key",
            "storage": "environment",
            "required": false
        },
        "lm_studio": {
            "type": "api_key",
            "storage": "environment",
            "required": false
        },
        "tgpt": {
            "type": "api_key",
            "storage": "environment",
            "required": false
        }
    },
    "audit": {
        "enabled": true,
        "log_path": ".config/credentials/audit.log",
        "events": [
            "key_rotation",
            "key_access",
            "permission_change",
            "credential_access"
        ],
        "retention": {
            "days": 90,
            "max_size": "100M"
        }
    },
    "validation": {
        "enabled": true,
        "rules": {
            "api_key": {
                "min_length": 32,
                "require_special": true,
                "require_numbers": true
            },
            "password": {
                "min_length": 12,
                "require_special": true,
                "require_numbers": true,
                "require_uppercase": true,
                "require_lowercase": true
            }
        }
    },
    "storage": {
        "type": "encrypted_file",
        "path": ".config/credentials/store",
        "backup": {
            "enabled": true,
            "interval": 86400,
            "retention": 7,
            "path": ".config/credentials/backups"
        }
    },
    "monitoring": {
        "enabled": true,
        "metrics": [
            "access_count",
            "rotation_count",
            "error_count",
            "validation_failures"
        ],
        "alerts": {
            "rotation_overdue": {
                "threshold": 86400,
                "severity": "warning"
            },
            "validation_failures": {
                "threshold": 5,
                "window": 300,
                "severity": "critical"
            }
        }
    }
}
